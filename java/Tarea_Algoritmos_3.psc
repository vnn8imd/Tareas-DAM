Algoritmo Tarea_Algoritmo_3
	
//Ejercicio 3: Realiza un conversor de Euros.
	
	//Defino variables y Asigno variables
	
	Definir pesetas Como Real;
	Definir euros Como Real;
		
	//Pedimos por pantalla valores
	
	Escribir "Programa para convertir pts a euros";
	Escribir "Ingresa la cantidad en pts";
	Leer pesetas;
	
	//Calculo conversión: Valor de pesetas introducido por el usuario, dividido entre las pesetas que son un euro (166.386)
	
	Escribir "euros", (pesetas / 166.386);
		
FinAlgoritmo
