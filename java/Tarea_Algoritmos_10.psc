Algoritmo Tarea_Algoritmo_10
	
	//Se pide por pantalla dos nºmeros, y el operador para realizar la operaciµn pertinente, suma, resta, 
	//multiplicaciµn y divisiµn.
	
	//Defino variables y asigno variables
	
	Definir n1,n2 Como Real;
		
	//Pedimos por pantalla valores
	
	Escribir "Escribe numero1";
	Leer n1
	
	Escribir "Escribe numero2";
	Leer n2
	
	Escribir "suma", (n1+n2)
	Escribir "resta", (n1-n2)
	Escribir "multiplicaciµn", (n1*n2)
	Escribir "divisiµn", (n1/n2)
		
	
FinAlgoritmo
