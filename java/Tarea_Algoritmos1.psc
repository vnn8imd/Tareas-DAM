Algoritmo Tarea_Algoritmo_1
	
//Ejercicio 1: Sumar dos números que se piden por pantalla.
	
	//Defino variables y Asigno variables
	
	Definir numero1,numero2 Como Real;
	Definir total Como Real;
	
	//Pedimos por pantalla valores
	
	Escribir "Escribe numero1";
	Leer numero1
	
	Escribir "Escribe numero2";
	Leer numero2
	
	//Calculamos la suma de los dos numeros
	
	total <- numero1+numero2
	
	// Mostramos el resultado
	
	Escribir total
	
FinAlgoritmo
